@model IEnumerable<AgriConnectPrototype.Models.SupplyContract>

@{
    ViewData["Title"] = "Index";
}

<h1>Supply Contracts</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Contract</a>
</p>

<form asp-action="Index" method="get" class="mb-3">
    <div class="row">

        <div class="col-md-2">
            <label>Start Date</label>
            <input type="date" name="startDate" class="form-control" />
        </div>

        <div class="col-md-2">
            <label>End Date</label>
            <input type="date" name="endDate" class="form-control" />
        </div>

        <div class="col-md-2">
            <label>Status</label>
            <select name="status" class="form-control">
                <option value="">All</option>
                <option value="Draft">Draft</option>
                <option value="Active">Active</option>
                <option value="Expired">Expired</option>
                <option value="On Hold">On Hold</option>
            </select>
        </div>

        <div class="col-md-2">
            <label>Region</label>
            <input type="text" name="region" class="form-control" />
        </div>

        <div class="col-md-2">
            <label>Produce Type</label>
            <select name="produceType" class="form-control">
                <option value="">All</option>
                <option value="Maize">Maize</option>
                <option value="Vegetables">Vegetables</option>
                <option value="Fruit">Fruit</option>
                <option value="Livestock">Livestock</option>
            </select>
        </div>

        <div class="col-md-2">
            <label>&nbsp;</label>
            <button type="submit" class="btn btn-success form-control">
                Search
            </button>
        </div>

    </div>
</form>

<table class="table table-bordered table-striped">

    <thead class="table-dark">
        <tr>
            <th>
                Farmer
            </th>

            <th>
                Start Date
            </th>

            <th>
                End Date
            </th>

            <th>
                Status
            </th>

            <th>
                Produce Type
            </th>

            <th>
                Service Level
            </th>

            <th>
                Agreement
            </th>

            <th>
                Actions
            </th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>
                    @Html.DisplayFor(modelItem => item.Farmer.FullName)
                </td>

                <td>
                    @Html.DisplayFor(modelItem => item.StartDate)
                </td>

                <td>
                    @Html.DisplayFor(modelItem => item.EndDate)
                </td>

                <td>
                    @Html.DisplayFor(modelItem => item.Status)
                </td>

                <td>
                    @Html.DisplayFor(modelItem => item.ProduceType)
                </td>

                <td>
                    @Html.DisplayFor(modelItem => item.ServiceLevel)
                </td>

                <td>
                    @if (!string.IsNullOrEmpty(item.SignedAgreementPath))
                    {
                        <a asp-action="DownloadAgreement"
                           asp-route-id="@item.SupplyContractId"
                           class="btn btn-sm btn-primary">
                            Download Agreement
                        </a>
                    }
                    else
                    {
                        <span>No file uploaded</span>
                    }
                </td>

                <td>
                    <a asp-action="Edit"
                       asp-route-id="@item.SupplyContractId"
                       class="btn btn-sm btn-warning">
                        Edit
                    </a>

                    <a asp-action="Details"
                       asp-route-id="@item.SupplyContractId"
                       class="btn btn-sm btn-info">
                        Details
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@item.SupplyContractId"
                       class="btn btn-sm btn-danger">
                        Delete
                    </a>
                </td>

            </tr>
        }

    </tbody>

</table>