@model AgriConnectPrototype.Models.FarmServiceRequest

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>FarmServiceRequest</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="SupplyContractId" class="control-label"></label>
                <select asp-for="SupplyContractId" class ="form-control" asp-items="ViewBag.SupplyContractId"></select>
            </div>
            <div class="form-group">
                <label asp-for="Description" class="control-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="UsdAmount" class="control-label">USD Amount</label>
                <input asp-for="UsdAmount" class="form-control" id="usdAmount" />
                <span asp-validation-for="UsdAmount" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Estimated ZAR Cost</label>
                <input class="form-control" id="zarCost" readonly />
            </div>

            <div class="form-group">
                <label asp-for="ExchangeRate" class="control-label"></label>
                <input asp-for="ExchangeRate" class="form-control" />
                <span asp-validation-for="ExchangeRate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CostInZar" class="control-label"></label>
                <input asp-for="CostInZar" class="form-control" />
                <span asp-validation-for="CostInZar" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Status" class="control-label"></label>
                <input asp-for="Status" class="form-control" />
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const estimatedRate = 18.50;

        document.getElementById("usdAmount").addEventListener("input", function () {
            let usd = parseFloat(this.value);

            if (!isNaN(usd)) {
                document.getElementById("zarCost").value = "R " + (usd * estimatedRate).toFixed(2);
            } else {
                document.getElementById("zarCost").value = "";
            }
        });
    </script>
}

